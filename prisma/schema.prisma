generator client {
  provider = "prisma-client-js"
  // Extra engine targets so `prisma generate` works both locally and on
  // Vercel's serverless runtime.
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // Pooled (Supabase transaction pooler) connection — used at runtime.
  url      = env("DATABASE_URL")
  // Direct/session connection — used for migrations & seeding.
  directUrl = env("DIRECT_URL")
}

model Problem {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  difficulty  String   // "Easy" | "Medium" | "Hard"
  description String   // markdown
  // The function name the judge will call in the user's submission.
  functionName String
  // Hint for the expected algorithm pattern (used only for seeding/demo copy;
  // the pipeline still detects the real pattern from the submitted code).
  patternHint String   // "two_pointer" | "bfs" | "unknown"
  starterCode String

  testCases   TestCase[]
  submissions Submission[]
  // A problem can belong to many topics (e.g. Number of Islands → BFS & DFS).
  topics      Topic[]  @relation("ProblemTopics")

  createdAt   DateTime @default(now())
}

model Topic {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  // Optional one-line blurb shown on the topic.
  blurb     String?
  ordinal   Int       @default(0)
  problems  Problem[] @relation("ProblemTopics")
  createdAt DateTime  @default(now())
}

model TestCase {
  id         String  @id @default(cuid())
  problemId  String
  problem    Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  // JSON-encoded array of arguments passed to the function, in order.
  inputJson  String
  // JSON-encoded expected return value.
  expectedJson String
  // Whether this case is shown to the user (sample) or hidden.
  isSample   Boolean @default(true)
  ordinal    Int     @default(0)
}

model Submission {
  id         String   @id @default(cuid())
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  sourceCode String
  language   String   @default("javascript")

  // "pending" | "passed" | "failed" | "error"
  status     String   @default("pending")
  // JSON-encoded TestRunResult[] (per-case results).
  resultsJson String  @default("[]")
  // JSON-encoded VisualizationPayload produced by the pipeline (null until run).
  pipelineJson String?

  createdAt  DateTime @default(now())
}
