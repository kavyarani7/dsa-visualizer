# Copy to `.env` and fill in. Never commit your real `.env`.

# SQLite for local dev. For a hosted deploy, point this at your database
# (and change the Prisma datasource `provider` accordingly).
DATABASE_URL="file:./dev.db"

# Optional. Without a key the pipeline's LLM nodes (algorithm-classification
# fallback and step narration) degrade gracefully to deterministic behavior —
# the app still runs end to end.
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-haiku-4-5"

# Sandbox engine for running submitted JS. Defaults to Node's built-in `vm`.
# Set to "isolated-vm" only if the native addon builds on your platform.
# SANDBOX_ENGINE="vm"
