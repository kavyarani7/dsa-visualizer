# Copy to `.env` and fill in. Never commit your real `.env`.

# --- Database (Supabase Postgres) ---
# DATABASE_URL: the POOLED "Transaction pooler" connection (port 6543).
#   Append ?pgbouncer=true — this is what the app uses at runtime.
# DIRECT_URL: the "Session pooler" / direct connection (port 5432).
#   Used for migrations (`prisma db push`) and seeding.
# Grab both from Supabase → Connect.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- LLM (optional) ---
# Without a key the pipeline's LLM nodes (algorithm-classification fallback and
# step narration) degrade gracefully to deterministic behavior.
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-haiku-4-5"

# --- Sandbox ---
# Engine for running submitted JS. Defaults to Node's built-in `vm`.
# SANDBOX_ENGINE="vm"
